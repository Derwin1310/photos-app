{
  "expo": {
    "name": "PicXplorer",
    "slug": "picxplorer",
    "version": "1.0.0",
    "scheme": "picxplorer",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#211e1d",
          "image": "./assets/splash-photojournal.png",
          "resizeMode": "contain",
          "imageWidth": 180
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Capture photos to save them to your personal gallery.",
        "NSPhotoLibraryAddUsageDescription": "Save captured photos to your library.",
        "NSPhotoLibraryUsageDescription": "Allow access when you choose to save or share photos."
      },
      "bundleIdentifier": "com.coderwin.picxplorer"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "package": "com.coderwin.picxplorer"
    }
  }
}
